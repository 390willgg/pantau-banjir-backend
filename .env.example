PORT=3000
API_PREFIX=api/v1
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/pantau_banjir?schema=public"
REDIS_URL=redis://localhost:6379
REDIS_REQUIRED=false
ENABLE_NOTIFICATIONS_QUEUE=false
CORS_ALLOWED_ORIGINS=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=credentials/firebase-admin.local.json
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=30
STALE_READING_MINUTES=15
MQTT_ENABLED=false
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=pantau-banjir-backend
MQTT_TOPIC_PATTERN=pantau-banjir/devices/+/readings

# HiveMQ Cloud example:
# MQTT_ENABLED=true
# MQTT_URL=mqtts://YOUR_HIVEMQ_CLUSTER_HOST.s1.eu.hivemq.cloud:8883
# MQTT_USERNAME=YOUR_HIVEMQ_USERNAME
# MQTT_PASSWORD=YOUR_HIVEMQ_PASSWORD
# MQTT_CLIENT_ID=pantau-banjir-backend
# MQTT_TOPIC_PATTERN=pantau-banjir/devices/+/readings

